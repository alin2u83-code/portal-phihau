VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CLAUDE_API_KEY=your_claude_api_key_here

# =============================================
# SMS NOTIFICATION SYSTEM
# =============================================

# Provider: android_gateway | smslink | twilio | vonage
SMS_PROVIDER=android_gateway

# Secret partajat între app și gateway (generează cu: openssl rand -hex 32)
SMS_CALLBACK_SECRET=your-random-32-char-secret-here

# Android SMS Gateway - URL public (ngrok sau Cloudflare Tunnel)
ANDROID_GATEWAY_URL=https://your-ngrok-url.ngrok.io
ANDROID_GATEWAY_TOKEN=your-gateway-bearer-token

# Rate limiting Orange Romania (SMS/oră și SMS/zi per club)
SMS_RATE_LIMIT_PER_HOUR=20
SMS_RATE_LIMIT_PER_DAY=100
