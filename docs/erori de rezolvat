SQL corecție date existente (de rulat manual în Supabase):
  UPDATE sportivi s
  SET grad_actual_id = ie.grad_id
  FROM inscrieri_examene ie
  JOIN sesiuni_examene se ON se.id = ie.sesiune_id
  WHERE ie.sportiv_id = s.id
    AND ie.rezultat = 'Admis'
    AND ie.grad_id IS NOT NULL
    AND se.data = (
      SELECT MAX(se2.data) FROM inscrieri_examene ie2
      JOIN sesiuni_examene se2 ON se2.id = ie2.sesiune_id
      WHERE ie2.sportiv_id = s.id AND ie2.rezultat = 'Admis'
    );

